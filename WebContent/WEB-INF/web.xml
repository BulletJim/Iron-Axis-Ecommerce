<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>iron-axis</display-name>
  
  <!-- Welcome Page -->
  <welcome-file-list>
  	<welcome-file>index.jsp</welcome-file> <!-- The landing page instantly redirects to CatalogServlet -->
  </welcome-file-list>
  
  <!-- DB Resource Declaration -->
  <resource-ref>
    <description>Iron Axis DB Connection</description>
    <res-ref-name>jdbc/IronAxisDB</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>
  
  
  <!-- Error pages Configuration -->
  <error-page>
  	<!-- Missing resource -->
  	<error-code>404</error-code>
  	<location>/error/error404.jsp</location>
  </error-page>
  <error-page>
  	<!-- Internal server Error -->
  	<error-code>500</error-code>
  	<location>/error/error500.jsp</location>
  </error-page>
  <error-page>
  	<!-- Forbidden Access -->
  	<error-code>403</error-code>
  	<location>/error/error403.jsp</location>
  </error-page>
  <!-- Bad Request -->
  <error-page>
    <error-code>400</error-code>
    <location>/error400.jsp</location>
</error-page>
<!-- Method Not Allowed -->
<error-page>
    <error-code>405</error-code>
    <location>/error405.jsp</location>
</error-page>
</web-app>